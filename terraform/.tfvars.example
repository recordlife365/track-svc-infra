# Copy to terraform.tfvars and fill in — never commit terraform.tfvars
cluster_name = "lifememo-cluster"
region       = "nyc3"
k8s_version  = "1.32.2-do.0" # run: doctl kubernetes options versions
node_size    = "s-2vcpu-4gb"
node_count   = 2
# do_token supplied via env: export DIGITALOCEAN_TOKEN=...
